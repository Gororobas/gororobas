{
  "name": "@gororobas/effect-bdd",
  "version": "0.0.0",
  "description": "BDD testing framework for Effect",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gororobas/gororobas-experiments",
    "directory": "packages/effect-bdd"
  },
  "bin": {
    "effect-bdd-check": "./bin/effect-bdd-check.js"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "build": "pnpm build-esm && pnpm build-annotate && pnpm build-cjs && build-utils pack-v2",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "type-check": "tsc -b tsconfig.json",
    "cli": "node bin/effect-bdd-check.js",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "dependencies": {
    "@cucumber/gherkin": "^38.0.0",
    "@cucumber/messages": "^32.0.1",
    "@effect/platform-bun": "catalog:",
    "effect": "catalog:",
    "glob": "catalog:"
  },
  "devDependencies": {
    "@effect/build-utils": "^0.7.9",
    "@effect/vitest": "catalog:",
    "@types/node": "^25.3.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  }
}
