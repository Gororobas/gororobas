{
  "name": "gororobas",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "type-check": "./node_modules/.bin/tsc -b tsconfig.json",
    "type-check-recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "lint": "oxlint --fix --fix-dangerously --type-aware --fix-suggestions --config=./.oxlintrc.json",
    "format": "oxfmt",
    "test": "bun --bun ./node_modules/vitest/vitest.mjs",
    "check-bdd": "bun run packages/effect-bdd/bin/effect-bdd-check.ts check",
    "coverage": "bun --bun ./node_modules/vitest/vitest.mjs --coverage",
    "quality-gates": "pnpm run type-check && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@effect/language-service": "^0.77.0",
    "@effect/vitest": "catalog:",
    "@manypkg/cli": "^0.25.1",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "3.2.4",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "bun": "1.3.12",
    "effect": "catalog:",
    "glob": "catalog:",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
