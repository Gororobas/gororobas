{
  "name": "gororobas",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "type-check": "tsc -b tsconfig.json",
    "type-check-recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "lint": "oxlint --fix --fix-dangerously --type-aware --fix-suggestions",
    "lint:dangerously": "oxlint --fix --type-aware --fix-suggestions --fix-dangerously",
    "format": "oxfmt",
    "test": "vitest",
    "coverage": "vitest --coverage"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@effect/build-utils": "^0.7.9",
    "@effect/language-service": "latest",
    "@effect/vitest": "latest",
    "@manypkg/cli": "^0.25.1",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "3.2.4",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "effect": "^3.19.19",
    "glob": "^13.0.6",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.27.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.12.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "patchedDependencies": {},
    "ignoredBuiltDependencies": [
      "better-sqlite3",
      "msgpackr-extract",
      "msw",
      "protobufjs",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@ariga/atlas",
      "@beads/bd",
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lefthook",
      "lmdb"
    ]
  }
}
