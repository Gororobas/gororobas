{
  "name": "gororobas",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "type-check": "./node_modules/.bin/tsc -b tsconfig.json",
    "type-check-recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "lint": "./node_modules/.bin/oxlint --fix --fix-dangerously --type-aware --fix-suggestions --config=./.oxlintrc.json",
    "lint:dangerously": "oxlint --fix --type-aware --fix-suggestions --fix-dangerously",
    "format": "oxfmt",
    "test": "bun --bun vitest",
    "check-bdd": "bun run packages/effect-bdd/bin/effect-bdd-check.ts check",
    "coverage": "bun --bun vitest --coverage",
    "quality-gates": "pnpm run type-check && pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@effect/language-service": "^0.77.0",
    "@effect/vitest": "catalog:",
    "@manypkg/cli": "^0.25.1",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "3.2.4",
    "babel-plugin-annotate-pure-calls": "^0.5.0",
    "bun": "^1.3.10",
    "effect": "catalog:",
    "glob": "catalog:",
    "lefthook": "^2.1.3",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "pnpm": ">=10.30.3 <11"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "patchedDependencies": {},
    "ignoredBuiltDependencies": [
      "@prisma/engines",
      "better-sqlite3",
      "msgpackr-extract",
      "msw",
      "prisma",
      "protobufjs",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@ariga/atlas",
      "@beads/bd",
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "lefthook",
      "lmdb",
      "bun"
    ]
  }
}
